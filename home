const PrimaryButton = ({ href, onClick, children, className = "" }) => {
  const base =
    "inline-flex items-center justify-center rounded-xl px-6 py-3 font-semibold text-white bg-red-600 hover:bg-red-700 active:bg-red-800 focus:outline-none focus:ring-2 focus:ring-red-300 shadow-md transition";
  if (href) return <a href={href} className={`${base} ${className}`}>{children}</a>;
  return (
    <button onClick={onClick} className={`${base} ${className}`}>
      {children}
    </button>
  );
};

