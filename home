      a: "Most windshield replacements take 60–90 minutes, plus safe drive-away time while the urethane cures.",
    },
  ];
  const [open, setOpen] = useState(null);
  return (
    <div className="divide-y divide-neutral-200">
      {items.map((it, i) => (
        <div key={i} className="py-4">
          <button
            className="w-full text-left flex items-center justify-between"
            onClick={() => setOpen(open === i ? null : i)}
          >
            <span className="font-semibold text-neutral-900">{it.q}</span>
            <span className="text-neutral-500">{open === i ? "−" : "+"}</span>
          </button>
          {open === i && <p className="mt-2 text-neutral-700">{it.a}</p>}
        </div>
      ))}
    </div>
  );
};

export default App;
