      className="w-full rounded-xl bg-white border border-neutral-300 focus:border-red-500 focus:ring-2 focus:ring-red-200 px-4 py-3 text-neutral-900 placeholder-neutral-400 min-h-[120px]"
      name={name}
      placeholder={placeholder}
      required={required}
      aria-label={label}
    />
  </label>
);

const SelectField = ({ label, name, options }) => (
  <label className="text-sm">
    <span className="block mb-1">{label}</span>
    <select
      name={name}
      className="w-full rounded-xl bg-white border border-neutral-300 focus:border-red-500 focus:ring-2 focus:ring-red-200 px-4 py-3 text-neutral-900"
      aria-label={label}
    >
      {options.map((o) => (
        <option key={o} value={o}>
          {o}
        </option>
      ))}
    </select>
  </label>
);

