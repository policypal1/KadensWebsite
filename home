const Field = ({ label, name, type = "text", required, placeholder }) => (
  <label className="text-sm">
    <span className="block mb-1">
      {label}
      {required && <span className="text-red-500"> *</span>}
    </span>
    <input
      className="w-full rounded-xl bg-white border border-neutral-300 focus:border-red-500 focus:ring-2 focus:ring-red-200 px-4 py-3 text-neutral-900 placeholder-neutral-400"
      type={type}
      name={name}
      placeholder={placeholder}
      required={required}
      aria-label={label}
    />
  </label>
);

const TextareaField = ({ label, name, required, placeholder }) => (
  <label className="text-sm">
    <span className="block mb-1">
      {label}
      {required && <span className="text-red-500"> *</span>}
    </span>
